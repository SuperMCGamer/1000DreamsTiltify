# Server port (Render sets this automatically)
PORT=3000

# Tiltify API credentials
# Get these from https://dashboard.tiltify.com/  → Developer → Applications
TILTIFY_CLIENT_ID=your_client_id_here
TILTIFY_CLIENT_SECRET=your_client_secret_here

# Your Tiltify Campaign ID (visible in the campaign URL or API)
TILTIFY_CAMPAIGN_ID=your_campaign_id_here

# How often to poll Tiltify for new donations (milliseconds, default 10000)
POLL_INTERVAL_MS=10000
